<view class="container">
  <view class="share-result-shell" wx:if="{{shareGateReady}}">
  <view class="share-result-layer {{(!shareUnlocked || gateChecking) ? 'share-result-layer-blurred' : ''}}">
  <view class="card">
    <view class="section-title">{{title}}</view>
    <view class="student-meta" wx:if="{{student}}">黑龙江 {{student.subject}} · {{student.score}}分 / {{student.rank}}名</view>
    <view class="student-meta" wx:if="{{archiveText}}">档案上下文：{{archiveText}}</view>
    <view class="student-meta" wx:if="{{fromRecommendText}}">{{fromRecommendText}}</view>
    <view class="student-meta" wx:if="{{student.targetMajor}}">意向专业：{{student.targetMajor}}</view>
    <view class="stats-row" wx:if="{{stats}}">
      <view class="stat-chip">段落 {{stats.blockCount}}</view>
      <view class="stat-chip">字数 {{stats.charCount}}</view>
    </view>
    <view class="suggestion-card" wx:if="{{suggestions.length}}">
      <view class="outline-title">可直接去院校库查看</view>
      <view class="suggestion-row">
        <block wx:for="{{suggestions}}" wx:key="id">
          <view class="suggestion-chip" data-keyword="{{item.keyword}}" data-subject="{{item.subject}}" bindtap="openExploreSuggestion">{{item.title}}</view>
        </block>
      </view>
    </view>
    <view class="outline-card" wx:if="{{familyBrief}}">
      <view class="outline-title">家长沟通版</view>
      <view class="family-brief">{{familyBrief}}</view>
      <view class="action-row family-action-row">
        <button class="ghost-btn action-btn" bindtap="copyFamilyBrief">复制沟通版</button>
        <button class="ghost-btn action-btn" bindtap="openFamilyShareCard">生成沟通卡片</button>
        <button class="ghost-btn action-btn" open-type="share">转发这页</button>
      </view>
    </view>
    <view class="outline-card" wx:if="{{outline.length}}">
      <view class="outline-title">报告导读</view>
      <block wx:for="{{outline}}" wx:key="id">
        <view class="outline-item">{{index + 1}}. {{item.text}}</view>
      </block>
    </view>
    <view class="suggestion-card" wx:if="{{checklist.length}}">
      <view class="outline-title">执行清单</view>
      <block wx:for="{{checklist}}" wx:key="*this">
        <view class="checklist-item">{{index + 1}}. {{item}}</view>
      </block>
    </view>
    <view class="outline-card" wx:if="{{vipPrompt}}">
      <view class="outline-title">继续深化决策</view>
      <view class="outline-item vip-prompt-desc">{{vipPrompt.desc}}</view>
      <block wx:for="{{vipPrompt.points}}" wx:key="*this">
        <view class="checklist-item">{{index + 1}}. {{item}}</view>
      </block>
      <view class="action-row family-action-row">
        <button class="ghost-btn action-btn" bindtap="openPlanList">去方案对比库</button>
        <button wx:if="{{showVipEntry}}" class="ghost-btn action-btn" bindtap="openVip">查看 VIP 中心</button>
      </view>
    </view>
    <scroll-view scroll-y="true" class="report-box">
      <block wx:for="{{reportBlocks}}" wx:key="id">
        <view class="report-block report-block-{{item.type}}">
          <text selectable="true">{{item.text}}</text>
        </view>
      </block>
    </scroll-view>
    <view class="action-row">
      <button class="ghost-btn" bindtap="backHome">返回首页</button>
      <button class="primary-btn action-btn" bindtap="copyReport">复制报告</button>
    </view>
  </view>
  </view>

  <view class="share-modal-mask" wx:if="{{gateChecking}}"></view>
  <view class="share-modal-card" wx:if="{{gateChecking}}">
    <view class="section-title">正在加载分析结果</view>
    <view class="share-lock-desc">正在确认分享权限与会员状态，请稍候。</view>
  </view>
  <view class="share-modal-mask" wx:if="{{!gateChecking && !shareUnlocked}}"></view>
  <view class="share-modal-card" wx:if="{{!gateChecking && !shareUnlocked}}">
    <view class="section-title">分享后查看 AI 报考分析</view>
    <view class="share-lock-desc">结果已经生成，当前先做模糊展示。分享当前小程序成功后，立即展示完整分析内容；分享文案不会带你的个人信息。</view>
    <button class="primary-btn" open-type="share" bindtap="requestShareUnlock">分享成功后查看完整结果</button>
  </view>
  </view>
</view>
