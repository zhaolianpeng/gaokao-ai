<view class="container diagnostics-page">
  <view class="card diagnostics-header">
    <view class="section-title">网络诊断</view>
    <view class="diagnostics-sub">这里会保留最近 20 条请求失败的完整信息，包含请求地址、运行环境和设备信息。</view>
    <button class="ghost-btn" bindtap="clearDiagnostics">清空诊断记录</button>
  </view>

  <view class="card diagnostics-empty" wx:if="{{!items.length}}">
    <view class="empty-title">暂无诊断记录</view>
    <view class="empty-text">当真机请求失败时，完整错误会自动保存到这里。</view>
  </view>

  <block wx:for="{{items}}" wx:key="id">
    <view class="card diagnostics-card">
      <view class="diagnostics-time">{{item.createdAt}}</view>
      <view class="diagnostics-message">{{item.message}}</view>
      <button class="primary-btn diagnostics-copy" data-index="{{index}}" bindtap="copyDiagnostic">复制这条诊断</button>
    </view>
  </block>
</view>