.login-page {
  min-height: 100vh;
  padding: 48rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-shell {
  width: 100%;
  max-width: 680rpx;
}

.login-hero {
  text-align: center;
  margin-bottom: 28rpx;
}

.login-badge {
  display: inline-block;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(31, 111, 235, 0.12);
  color: #1f6feb;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-bottom: 18rpx;
}

.login-title {
  font-size: 48rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #10233f;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 28rpx;
  line-height: 1.8;
  color: #5c6f86;
  max-width: 620rpx;
  margin: 0 auto;
}

.login-card {
  background: transparent;
  box-shadow: none;
  border-radius: 0;
  margin-bottom: 0;
  padding: 36rpx 32rpx;
}

.login-card-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #10233f;
  text-align: center;
}

.login-card-desc {
  margin-top: 12rpx;
  margin-bottom: 28rpx;
  font-size: 26rpx;
  line-height: 1.7;
  text-align: center;
  color: #6a7c92;
}

.login-field {
  margin-bottom: 22rpx;
}

.login-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #27415f;
  margin-bottom: 12rpx;
}

.login-input {
  background: #f6f9fc;
  border: 2rpx solid #d9e4f1;
  border-radius: 16rpx;
  height: 88rpx;
  padding: 0 24rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  color: #1d2a39;
  box-sizing: border-box;
  width: 100%;
}

.login-submit {
  margin-top: 12rpx;
}

.login-submit::after,
.login-demo-btn::after {
  border: 0;
  display: none;
}

.login-consent-box {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  margin-top: 10rpx;
  padding: 22rpx;
  background: #f6f9fc;
  border: 2rpx solid #d9e4f1;
  border-radius: 18rpx;
}

.login-consent-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 10rpx;
  border: 2rpx solid #b6c6d8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #ffffff;
  background: #ffffff;
  flex-shrink: 0;
  margin-top: 6rpx;
}

.login-consent-check-active {
  background: #1f6feb;
  border-color: #1f6feb;
}

.login-consent-copy {
  flex: 1;
}

.login-consent-text {
  font-size: 24rpx;
  line-height: 1.8;
  color: #42556d;
}

.login-consent-links {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.login-consent-link {
  font-size: 24rpx;
  line-height: 1.6;
  color: #1f6feb;
}

.login-consent-divider {
  font-size: 22rpx;
  color: #8b9bb0;
}

.login-demo-btn {
  margin-top: 18rpx;
}

.login-tip {
  font-size: 26rpx;
  line-height: 1.7;
  color: #6a7c92;
}

.login-footnote {
  margin-top: 22rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7a8ca3;
}