.container {
  padding: 28rpx;
}

.hero-card {
  background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(242,247,255,0.98));
}

.meta {
  color: #60748d;
  font-size: 24rpx;
}

.input {
  margin-top: 20rpx;
  background: #f6f9ff;
  border-radius: 14rpx;
  padding: 20rpx;
}

.keyword-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.sort-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.keyword-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #284b75;
  font-size: 22rpx;
}

.sort-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #f2f6fd;
  color: #466483;
  font-size: 22rpx;
  border: 1rpx solid rgba(145, 171, 209, 0.22);
}

.sort-chip-active {
  background: linear-gradient(180deg, #e3efff, #f0f6ff);
  color: #1858d6;
  border-color: rgba(24, 88, 214, 0.26);
  font-weight: 700;
}

.picker-field {
  color: #38597f;
}

.primary-btn {
  margin-top: 20rpx;
}

.result-tip {
  margin-top: 14rpx;
  color: #60748d;
  font-size: 23rpx;
}

.filter-summary-card {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, rgba(236, 244, 255, 0.95), rgba(247, 250, 255, 0.98));
  border: 1rpx solid rgba(145, 171, 209, 0.22);
}

.filter-summary-label {
  font-size: 21rpx;
  color: #69809c;
}

.filter-summary-value {
  margin-top: 8rpx;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.6;
  color: #16355b;
}

.page-summary {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #3f5f84;
}

.empty-state {
  margin: 8rpx 0 20rpx;
  padding: 34rpx 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(244,248,255,0.98));
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #16355b;
}

.empty-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #60748d;
}

.college-card {
  margin-bottom: 20rpx;
}

.row-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.college-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #16355b;
}

.college-meta {
  margin-top: 10rpx;
  color: #60748d;
  font-size: 24rpx;
}

.rank-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #175cd3;
  font-size: 22rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f2f7ff;
  color: #38597f;
  font-size: 22rpx;
}

.stat-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.stat-item {
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f8fbff;
  color: #38597f;
  font-size: 24rpx;
}

.list-status {
  padding: 16rpx 0 28rpx;
  text-align: center;
  font-size: 23rpx;
  color: #60748d;
}

.list-status-warn {
  color: #8b5a16;
}
