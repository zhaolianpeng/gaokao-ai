<view class="profile-edit-page">
  <view class="profile-edit-shell">
    <view class="card profile-edit-card">
      <view class="profile-edit-title">编辑昵称和报考档案</view>
      <view class="profile-edit-desc">原生输入组件统一放到这个独立编辑页，避免“我的”页真机出现同层残影。</view>

      <view class="profile-edit-field">
        <view class="profile-edit-label">昵称</view>
        <input class="input profile-edit-input" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput" always-embed="true" />
      </view>

      <view class="profile-edit-field">
        <view class="profile-edit-label">地区</view>
        <view class="profile-edit-static">黑龙江</view>
      </view>

      <view class="profile-edit-field">
        <view class="profile-edit-label">科类</view>
        <picker mode="selector" range="{{subjectOptions}}" bindchange="onSubjectChange">
          <view class="profile-edit-picker">{{profile.subject}}</view>
        </picker>
      </view>

      <view class="profile-edit-field">
        <view class="profile-edit-label">学校</view>
        <picker wx:if="{{schoolOptions.length}}" mode="selector" range="{{schoolOptions}}" range-key="label" value="{{schoolOptions.length ? 0 : 0}}" bindchange="onSchoolChange">
          <view class="profile-edit-picker">{{profile.schoolName || '请选择学校'}}</view>
        </picker>
        <view wx:else class="profile-edit-static">请先在 MIS 配置学校选项</view>
      </view>

      <view class="profile-edit-field">
        <view class="profile-edit-label">学年</view>
        <picker wx:if="{{schoolYearOptions.length}}" mode="selector" range="{{schoolYearOptions}}" range-key="label" bindchange="onSchoolYearChange">
          <view class="profile-edit-picker">{{profile.schoolYear || '请选择学年'}}</view>
        </picker>
        <view wx:else class="profile-edit-static">请先在 MIS 配置学年选项</view>
      </view>

      <view class="profile-edit-field">
        <view class="profile-edit-label">班级</view>
        <picker wx:if="{{classOptions.length}}" mode="selector" range="{{classOptions}}" range-key="label" bindchange="onClassChange">
          <view class="profile-edit-picker">{{profile.className || '请选择班级'}}</view>
        </picker>
        <view wx:else class="profile-edit-static">请先在 MIS 配置班级选项</view>
      </view>

      <view class="profile-edit-field">
        <view class="profile-edit-label">学号</view>
        <input class="input profile-edit-input" placeholder="请输入学号" value="{{profile.studentNo}}" data-field="studentNo" bindinput="onInput" always-embed="true" />
      </view>

      <view class="profile-edit-field">
        <view class="profile-edit-label">是否通过推荐过来</view>
        <switch checked="{{profile.fromRecommend}}" bindchange="onFromRecommendChange" color="#1f6feb"></switch>
      </view>

      <view class="profile-edit-field">
        <view class="profile-edit-label">高考分数</view>
        <input class="input profile-edit-input" type="number" placeholder="请输入分数" value="{{profile.score}}" data-field="score" bindinput="onInput" always-embed="true" />
      </view>

      <view class="profile-edit-field">
        <view class="profile-edit-label">全省排名</view>
        <input class="input profile-edit-input" type="number" placeholder="请输入位次" value="{{profile.rank}}" data-field="rank" bindinput="onInput" always-embed="true" />
      </view>

      <view class="profile-edit-field">
        <view class="profile-edit-label">意向专业</view>
        <input class="input profile-edit-input" placeholder="例如：计算机、临床医学" value="{{profile.targetMajor}}" data-field="targetMajor" bindinput="onInput" always-embed="true" />
      </view>

      <view class="profile-edit-field">
        <view class="profile-edit-label">报考偏好</view>
        <textarea class="textarea profile-edit-textarea" placeholder="例如：优先哈尔滨、接受调剂、尽量公办" value="{{profile.notes}}" data-field="notes" bindinput="onInput" disable-default-padding="true"></textarea>
      </view>

      <view class="profile-edit-desc" wx:if="{{optionsLoading}}">正在加载学校、学年和班级配置...</view>

      <view class="ghost-btn profile-edit-action" hover-class="profile-edit-action-hover" bindtap="syncNickname">{{syncSubmitting ? '同步中...' : '同步昵称到当前账号'}}</view>
      <view class="primary-btn profile-edit-action" hover-class="profile-edit-action-hover" bindtap="saveProfile">{{saveSubmitting ? '保存中...' : '保存报考档案'}}</view>
    </view>
  </view>
</view>