.profile-edit-page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.profile-edit-shell {
  max-width: 680rpx;
  margin: 0 auto;
}

.profile-edit-card {
  padding: 32rpx;
}

.profile-edit-title {
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #10233f;
}

.profile-edit-desc {
  margin-top: 12rpx;
  margin-bottom: 28rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #607389;
}

.profile-edit-field {
  margin-bottom: 22rpx;
}

.profile-edit-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #27415f;
  margin-bottom: 12rpx;
}

.profile-edit-picker,
.profile-edit-static {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  background: #f6f9fc;
  border: 2rpx solid #d9e4f1;
  border-radius: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1d2a39;
}

.profile-edit-input {
  min-height: 88rpx;
  padding: 20rpx 24rpx;
  background: #f6f9fc;
  border: 2rpx solid #d9e4f1;
  border-radius: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.5;
  color: #1d2a39;
  width: 100%;
}

.profile-edit-textarea {
  min-height: 180rpx;
  padding: 20rpx 24rpx;
  background: #f6f9fc;
  border: 2rpx solid #d9e4f1;
  border-radius: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
  color: #1d2a39;
  width: 100%;
}

.profile-edit-action {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  width: 100%;
  min-height: 88rpx;
  border-radius: 16rpx;
  box-sizing: border-box;
  margin-top: 18rpx;
}

.profile-edit-action-hover {
  opacity: 0.92;
}