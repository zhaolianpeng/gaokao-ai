.container {
  padding: 28rpx;
}

.row-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.meta {
  color: #5c708a;
  font-size: 25rpx;
  margin-top: 8rpx;
}

.link-btn {
  color: #175cd3;
  font-size: 24rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.header-count {
  font-size: 22rpx;
  color: #5c708a;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.quick-summary {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.quick-summary-item {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f8fbff;
}

.quick-summary-label {
  font-size: 23rpx;
  color: #60748d;
}

.quick-summary-text {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #16355b;
  font-weight: 600;
  line-height: 1.6;
}

.page-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.ghost-btn {
  flex: 1;
  border-radius: 16rpx;
  background: #eef5ff;
  color: #175cd3;
  font-size: 24rpx;
}

.summary-card {
  padding: 18rpx;
  border-radius: 18rpx;
  text-align: center;
}

.summary-chong {
  background: #fff0f0;
}

.summary-wen {
  background: #eefaf2;
}

.summary-bao {
  background: #eff5ff;
}

.summary-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #16355b;
}

.summary-label {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #60748d;
}

.section-card {
  overflow: hidden;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.section-header-left {
  flex: 1;
  min-width: 0;
}

.section-header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.section-subtitle {
  margin-top: 10rpx;
  color: #60748d;
  font-size: 24rpx;
  line-height: 1.6;
}

.section-count {
  font-size: 22rpx;
  color: #60748d;
}

.section-arrow {
  font-size: 24rpx;
  font-weight: 700;
  color: #175cd3;
}

.section-body {
  margin-top: 20rpx;
  padding-left: 18rpx;
  border-left: 4rpx solid #dbe7f6;
}

.tag {
  display: inline-block;
  margin-bottom: 14rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.chong { background: #ffe7e7; color: #b42318; }
.wen { background: #e9f9ef; color: #067647; }
.bao { background: #e6f0ff; color: #175cd3; }

.item {
  padding: 20rpx 0;
  border-bottom: 1rpx dashed #e7edf6;
  color: #1e2f45;
}

.item-nested {
  padding-left: 14rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 700;
}

.item-sub {
  margin-top: 8rpx;
  color: #60748d;
  font-size: 25rpx;
}

.item-prob {
  margin-top: 10rpx;
  color: #175cd3;
  font-size: 24rpx;
}

.item-reason {
  margin-top: 10rpx;
  color: #3b587c;
  font-size: 23rpx;
  line-height: 1.7;
}

.item-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 16rpx;
}

.item-action {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #34577d;
  font-size: 23rpx;
}

.item-action-active {
  background: #dceafe;
  color: #175cd3;
}

.item-action-primary {
  background: #175cd3;
  color: #ffffff;
}

.strategy-box {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #183250, #1f6feb);
  color: #ffffff;
}

.strategy-title {
  font-size: 30rpx;
  font-weight: 700;
}

.strategy-text {
  margin-top: 10rpx;
  line-height: 1.7;
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.88);
}

.strategy-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.strategy-card {
  padding: 22rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f8fbff, #eef5ff);
}

.strategy-card-title,
.decision-title,
.compare-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #16355b;
}

.strategy-card-desc,
.strategy-card-note,
.decision-desc,
.compare-sub {
  margin-top: 8rpx;
  color: #60748d;
  font-size: 24rpx;
  line-height: 1.7;
}

.strategy-card-focus {
  margin-top: 12rpx;
  font-size: 25rpx;
  color: #1f4f7e;
  font-weight: 600;
}

.compare-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx dashed #e7edf6;
}

.vip-compare-row:last-child {
  border-bottom: none;
}

.compare-tag {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e8f1ff;
  color: #175cd3;
  font-size: 22rpx;
  font-weight: 700;
}

.vip-tag-gold {
  background: #fff1cc;
  color: #9a6700;
}

.compare-main,
.decision-body {
  flex: 1;
}

.decision-step {
  display: flex;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx dashed #e7edf6;
}

.decision-index {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #16355b;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 6rpx;
}

.family-summary-box {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #f8fbff, #eef5ff);
  color: #38597f;
  font-size: 25rpx;
  line-height: 1.8;
  white-space: pre-wrap;
}

.strategy-action-row {
  margin-top: 16rpx;
}

.analyze-progress-track {
  margin-top: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #e8eff8;
  overflow: hidden;
}

.analyze-progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #175cd3, #4f9cff);
}

.analyze-progress-label,
.analyze-helper-text {
  margin-top: 10rpx;
  color: #60748d;
  font-size: 23rpx;
  line-height: 1.7;
}

.analyze-panel {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(239, 245, 255, 0.98));
  border: 1rpx solid #d9e6f7;
}

.analyze-panel-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #16355b;
}

.analyze-panel-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5c708a;
}

.analyze-panel-tag {
  display: inline-block;
  margin-top: 14rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e6f0ff;
  color: #175cd3;
  font-size: 22rpx;
  font-weight: 700;
}

.primary-btn {
  margin-top: 20rpx;
}

@media (max-width: 420px) {
  .page-actions,
  .item-actions {
    flex-direction: column;
  }
}
