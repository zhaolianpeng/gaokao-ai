<view class="container">
  <view class="card" wx:if="{{loadError}}">
    <view class="section-title">资料库暂时不可用</view>
    <view class="material-summary">{{loadError}}</view>
  </view>

  <block wx:if="{{!loadError}}">
  <view class="hero">
    <view class="hero-badge">内置资料库</view>
    <view class="hero-title">报考资料</view>
    <view class="hero-sub">把你整理的警校、军校、专项计划、综合评价和选校方法直接接进小程序，随时可查。</view>
  </view>

  <view class="card">
    <view class="section-title">优先阅读</view>
    <block wx:for="{{featured}}" wx:key="id">
      <view class="featured-item" data-id="{{item.id}}" bindtap="openMaterial">
        <view class="featured-top">
          <view class="category-pill">{{item.category}}</view>
          <view class="arrow">查看</view>
        </view>
        <view class="featured-title">{{item.title}}</view>
        <view class="featured-summary">{{item.summary}}</view>
      </view>
    </block>
  </view>

  <view class="card">
    <view class="section-title">全部资料</view>
    <block wx:for="{{materials}}" wx:key="id">
      <view class="material-item" data-id="{{item.id}}" bindtap="openMaterial">
        <view class="material-main">
          <view class="row-between row-start">
            <view class="material-title">{{item.title}}</view>
            <view class="category-tag">{{item.category}}</view>
          </view>
          <view class="material-summary">{{item.summary}}</view>
          <view class="tag-row">
            <block wx:for="{{item.tags}}" wx:for-item="tagItem" wx:key="*this">
              <view class="tag">{{tagItem}}</view>
            </block>
          </view>
        </view>
      </view>
    </block>
  </view>
  </block>
</view>