.container {
  padding: 28rpx;
}

.hero-card {
  background: linear-gradient(135deg, rgba(22,53,91,0.98), rgba(28,107,185,0.9));
  color: #fff;
}

.title {
  font-size: 42rpx;
  font-weight: 800;
}

.meta {
  margin-top: 10rpx;
  color: rgba(255,255,255,0.84);
  font-size: 24rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.14);
  color: #fff;
  font-size: 22rpx;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 20rpx;
}

.stat-card {
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.12);
}

.stat-value {
  font-size: 34rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.76);
}

.ghost-btn {
  margin-top: 20rpx;
  background: rgba(255,255,255,0.16);
  color: #fff;
  border-radius: 16rpx;
}

.group-item,
.major-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf2f8;
}

.group-title,
.major-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #16355b;
}

.group-meta,
.major-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #60748d;
}

.timeline {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.timeline-item {
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f8fbff;
}

.timeline-year {
  font-size: 24rpx;
  font-weight: 700;
  color: #175cd3;
}

.timeline-text {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #38597f;
}