.vip-page {
  min-height: 100vh;
  padding: 32rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.vip-shell {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.vip-hero-card,
.vip-product-card {
  padding: 32rpx;
}

.vip-badge {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(31, 111, 235, 0.12);
  color: #1f6feb;
  font-size: 24rpx;
  font-weight: 700;
}

.vip-title {
  margin-top: 18rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #10233f;
}

.vip-desc {
  margin-top: 16rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: #5c6f86;
}

.vip-login-btn {
  margin-top: 24rpx;
}

.vip-user {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #27415f;
}

.vip-status {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  font-size: 25rpx;
  line-height: 1.6;
}

.vip-status-ok {
  background: rgba(22, 163, 74, 0.08);
  color: #166534;
}

.vip-status-warn {
  background: rgba(217, 119, 6, 0.1);
  color: #9a3412;
}

.vip-band-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.vip-band-card {
  padding: 22rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f8fbff, #eef5ff);
}

.vip-band-label {
  font-size: 24rpx;
  color: #5c6f86;
  font-weight: 700;
}

.vip-band-price {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #10233f;
}

.vip-band-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6a7c92;
}

.vip-access-table {
  margin-top: 22rpx;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid #e4ecf6;
}

.vip-access-head,
.vip-access-row {
  display: grid;
  grid-template-columns: 1.8fr repeat(4, 1fr);
}

.vip-access-head {
  background: #eef5ff;
}

.vip-access-row:nth-child(even) {
  background: #fbfdff;
}

.vip-access-cell {
  padding: 18rpx 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #4c6078;
  border-right: 1rpx solid #e4ecf6;
  border-bottom: 1rpx solid #e4ecf6;
  text-align: center;
}

.vip-access-head .vip-access-cell {
  font-weight: 700;
  color: #10233f;
}

.vip-access-feature {
  text-align: left;
}

.vip-product-meta-row {
  margin-top: 18rpx;
}

.vip-product-meta-chip {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #175cd3;
  font-size: 22rpx;
  font-weight: 700;
}

.vip-product-meta-text {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #556b84;
}

.vip-highlight-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 16rpx;
}

.vip-highlight-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 10rpx;
  border-radius: 50%;
  background: #1f6feb;
  flex-shrink: 0;
}

.vip-highlight-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: #5c6f86;
}

.vip-product-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.vip-product-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #10233f;
}

.vip-product-title-row {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  flex-wrap: wrap;
}

.vip-product-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #c2410c;
}

.vip-product-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #6a7c92;
}

.vip-buy-btn {
  margin-top: 24rpx;
}

.vip-product-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.vip-product-badge {
  background: #fff1cc;
  color: #9a6700;
}