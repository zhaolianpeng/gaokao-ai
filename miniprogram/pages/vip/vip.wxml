<view class="vip-page">
  <view class="vip-shell">
    <view class="card vip-hero-card">
      <view class="vip-badge">VIP 中心</view>
      <view class="vip-title">按竞品主流价带，把套餐边界讲清楚</view>
      <view class="vip-desc">基础查询和 5 层推荐继续免费开放。真正适合付费的，是需要深度 AI 解释、长期保存多套方案、反复和家长老师讨论的高频决策场景。购买前需要先完成手机号快捷登录，这样服务端才能绑定账号并创建支付订单。</view>
      <button wx:if="{{!user}}" class="primary-btn vip-login-btn" bindtap="goLogin">先去登录</button>
      <view wx:if="{{user}}" class="vip-user">当前账号：{{user.nickname}}{{user.phone ? '（' + user.phone + '）' : ''}}</view>
      <view class="vip-status {{canPay ? 'vip-status-ok' : 'vip-status-warn'}}">{{loginHint}}</view>
      <view class="vip-membership-card" wx:if="{{vipMembershipLoaded && user}}">
        <view class="vip-membership-head">
          <view class="vip-membership-title">当前账号 VIP 信息</view>
          <view class="vip-membership-tag {{vipMembership && vipMembership.active ? 'vip-membership-tag-active' : 'vip-membership-tag-idle'}}">{{vipMembership && vipMembership.statusText ? vipMembership.statusText : '未开通'}}</view>
        </view>
        <block wx:if="{{vipMembership && vipMembership.productName}}">
          <view class="vip-membership-name">{{vipMembership.productName}}</view>
          <view class="vip-membership-line">级别：{{vipMembership.levelText || '长期'}} ｜ {{vipMembership.validityText || '长期有效'}}</view>
          <view class="vip-membership-line">起始时间：{{vipMembership.startText || '—'}}</view>
          <view class="vip-membership-line">结束时间：{{vipMembership.endText || '—'}}</view>
        </block>
        <view wx:else class="vip-membership-line">当前账号还没有已生效的 VIP 会员。</view>
      </view>
    </view>

    <view class="card vip-product-card">
      <view class="vip-product-title">市场价格带锚点</view>
      <view class="vip-product-desc">主流高考报考产品的价格，大致落在这 4 个区间。当前页面直接把你的套餐放进这个坐标系里。</view>
      <view class="vip-band-grid">
        <block wx:for="{{priceBands}}" wx:key="label">
          <view class="vip-band-card">
            <view class="vip-band-label">{{item.label}}</view>
            <view class="vip-band-price">{{item.price}}</view>
            <view class="vip-band-desc">{{item.desc}}</view>
          </view>
        </block>
      </view>
    </view>

    <view class="card vip-product-card">
      <view class="vip-product-title">权益对比</view>
      <view class="vip-product-desc">把“免费 / 轻量体验 / 标准决策 / 全周期”四层讲清楚，用户更容易知道自己该买哪档。</view>
      <view class="vip-access-table">
        <view class="vip-access-head">
          <view class="vip-access-cell vip-access-feature">能力</view>
          <view class="vip-access-cell">免费</view>
          <view class="vip-access-cell">轻量</view>
          <view class="vip-access-cell">标准</view>
          <view class="vip-access-cell">全程</view>
        </view>
        <block wx:for="{{accessMatrix}}" wx:key="feature">
          <view class="vip-access-row">
            <view class="vip-access-cell vip-access-feature">{{item.feature}}</view>
            <view class="vip-access-cell">{{item.free}}</view>
            <view class="vip-access-cell">{{item.lite}}</view>
            <view class="vip-access-cell">{{item.core}}</view>
            <view class="vip-access-cell">{{item.full}}</view>
          </view>
        </block>
      </view>
    </view>

    <view class="card vip-product-card">
      <view class="vip-product-title">套餐建议</view>
      <view class="vip-product-desc">套餐不是越贵越好，关键是和你的使用频次、决策周期、复盘需求匹配。</view>
    </view>

    <view class="card vip-product-card" wx:for="{{products}}" wx:key="id">
      <view class="vip-product-head">
        <view>
          <view class="vip-product-title-row">
            <view class="vip-product-title">{{item.title}}</view>
            <view class="vip-product-price">{{item.priceText}}</view>
          </view>
          <view class="vip-product-desc">{{item.desc}}</view>
        </view>
        <view class="vip-product-badge">{{item.badge}}</view>
      </view>
      <view class="vip-product-meta-row">
        <view class="vip-product-meta-chip">{{item.anchorText}}</view>
        <view class="vip-product-meta-text">{{item.suitedFor}}</view>
      </view>
      <block wx:for="{{item.highlights}}" wx:key="index">
        <view class="vip-highlight-row">
          <view class="vip-highlight-dot"></view>
          <view class="vip-highlight-text">{{item}}</view>
        </view>
      </block>
      <button class="primary-btn vip-buy-btn" data-product-id="{{item.id}}" bindtap="purchase" loading="{{loadingProductId === item.id}}">立即购买</button>
    </view>
  </view>
</view>