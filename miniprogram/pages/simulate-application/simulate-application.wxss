.simulate-page {
  gap: 24rpx;
}

.simulate-step-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(31, 58, 95, 0.08);
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.simulate-step-item:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.simulate-step-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #17324d;
}

.simulate-step-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #61748a;
}

.simulate-step-status {
  flex-shrink: 0;
  min-width: 120rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #edf2f7;
  color: #61748a;
  font-size: 22rpx;
  text-align: center;
}

.simulate-step-status-done {
  background: rgba(41, 160, 103, 0.14);
  color: #1f7a4c;
}

.simulate-next-action {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #17324d;
}

.simulate-mode-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.simulate-mode-card {
  padding: 24rpx 20rpx;
  border-radius: 24rpx;
  background: #f6f8fb;
  border: 2rpx solid transparent;
}

.simulate-mode-card-active {
  background: rgba(31, 111, 235, 0.08);
  border-color: rgba(31, 111, 235, 0.4);
}

.simulate-mode-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #17324d;
}

.simulate-mode-desc {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #61748a;
}

.simulate-action-grid {
  margin-top: 20rpx;
}

.simulate-action-grid .ghost-btn,
.simulate-action-grid .primary-btn {
  min-width: 0;
}

.simulate-pending-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.simulate-score-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.simulate-score-badge-excellent {
  background: rgba(41, 160, 103, 0.14);
  color: #1f7a4c;
}

.simulate-score-badge-good {
  background: rgba(31, 111, 235, 0.12);
  color: #1f6feb;
}

.simulate-score-badge-warning {
  background: rgba(245, 158, 11, 0.14);
  color: #b45309;
}

.simulate-score-badge-danger {
  background: rgba(220, 38, 38, 0.12);
  color: #b91c1c;
}

.simulate-score-badge-pending {
  background: #edf2f7;
  color: #61748a;
}

.simulate-risk-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.simulate-risk-metric {
  padding: 22rpx 20rpx;
  border-radius: 20rpx;
  background: #f6f8fb;
}

.simulate-risk-label {
  font-size: 24rpx;
  color: #61748a;
}

.simulate-risk-value {
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #17324d;
}

.simulate-advice-block {
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #f9fbfd;
}

.simulate-advice-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #17324d;
}

.simulate-advice-line {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #61748a;
}

.simulate-status-row {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #f4f7fb;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.simulate-status-label {
  font-size: 26rpx;
  color: #61748a;
}

.simulate-status-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f6feb;
}