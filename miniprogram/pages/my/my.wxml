<view class="my-page">
  <view class="my-shell">
    <view class="card my-hero-card" wx:if="{{!user}}">
      <view class="my-title">我的</view>
      <view class="my-desc">登录后可保存考分、排名和报考偏好，并在首页自动带出。</view>
      <view class="ghost-btn my-ghost-btn my-action-btn" hover-class="my-btn-hover" bindtap="openAboutPage">关于我们</view>
      <view class="primary-btn my-primary-btn my-action-btn" hover-class="my-btn-hover" bindtap="goLogin">去登录</view>
      <view class="ghost-btn my-ghost-btn my-action-btn" hover-class="my-btn-hover" bindtap="useDemoAccount">快速体验</view>
    </view>

    <view class="card my-profile-card" wx:if="{{user}}">
      <view class="my-badge">已登录</view>
      <view class="profile-head">
        <view class="profile-avatar-shell">
          <image wx:if="{{avatarDisplayUrl}}" class="profile-avatar" src="{{avatarDisplayUrl}}" mode="aspectFill"></image>
          <view wx:else class="profile-avatar profile-avatar-placeholder">{{userInitial}}</view>
          <button class="profile-avatar-trigger" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" loading="{{avatarSubmitting}}"></button>
          <view class="profile-avatar-tip">{{avatarSubmitting ? '上传中' : '点头像更新'}}</view>
        </view>
        <view class="profile-meta">
          <view class="profile-title">{{user.nickname}}</view>
          <view class="profile-subtitle" wx:if="{{user.phone}}">手机号：{{user.phone}}</view>
        </view>
      </view>
      <view class="login-footnote">登录后保存的考分和偏好会在首页自动带出。</view>
      <view class="my-vip-card" wx:if="{{vipMembershipLoaded}}">
        <view class="my-vip-head">
          <view class="my-vip-title">当前 VIP</view>
          <view class="my-vip-tag {{vipMembership && vipMembership.active ? 'my-vip-tag-active' : 'my-vip-tag-inactive'}}">{{vipMembership && vipMembership.statusText ? vipMembership.statusText : '未开通'}}</view>
        </view>
        <block wx:if="{{vipMembership && vipMembership.productName}}">
          <view class="my-vip-name">{{vipMembership.productName}}</view>
          <view class="my-vip-desc">级别：{{vipMembership.levelText || '长期'}} ｜ {{vipMembership.validityText || '长期有效'}}</view>
          <view class="my-vip-time">起始时间：{{vipMembership.startText || '—'}}</view>
          <view class="my-vip-time">结束时间：{{vipMembership.endText || '—'}}</view>
        </block>
        <view wx:else class="my-vip-empty">你当前还没有开通生效中的 VIP 会员。</view>
      </view>
      <view class="my-sync-card">
        <view class="my-sync-title">管理昵称、头像和档案</view>
        <view class="my-sync-desc">头像请直接点击上方头像更新。昵称和报考档案请进入编辑页统一修改并保存。</view>
        <view class="ghost-btn my-ghost-btn my-action-btn" hover-class="my-btn-hover" bindtap="openProfileEditor">编辑昵称和档案</view>
      </view>
      <view wx:if="{{showVipEntry}}" class="primary-btn my-primary-btn my-action-btn" hover-class="my-btn-hover" bindtap="openVip">进入 VIP 中心</view>
    </view>

    <view class="card my-form-card" wx:if="{{user}}">
      <view class="my-form-title">我的报考档案</view>
      <view class="my-form-desc">完善基础信息后，可在推荐页和首页直接复用，减少重复填写。</view>

      <view class="my-field-card">
        <view class="login-label">地区：</view>
        <view class="my-static-value">黑龙江</view>
      </view>

      <view class="my-field-card">
        <view class="login-label">科类：</view>
        <view class="my-static-value">{{profile.subject || '未填写'}}</view>
      </view>

      <view class="my-field-card">
        <view class="login-label">学校：</view>
        <view class="my-static-value">{{profile.schoolName || '未填写'}}</view>
      </view>

      <view class="my-field-card">
        <view class="login-label">学年：</view>
        <view class="my-static-value">{{profile.schoolYear || '未填写'}}</view>
      </view>

      <view class="my-field-card">
        <view class="login-label">班级：</view>
        <view class="my-static-value">{{profile.className || '未填写'}}</view>
      </view>

      <view class="my-field-card">
        <view class="login-label">学号：</view>
        <view class="my-static-value">{{profile.studentNo || '未填写'}}</view>
      </view>

      <view class="my-field-card">
        <view class="login-label">推荐来源：</view>
        <view class="my-static-value">{{profile.fromRecommend ? '是' : '否'}}</view>
      </view>

      <view class="my-field-card">
        <view class="login-label">高考分数：</view>
        <view class="my-static-value">{{profile.score || '未填写'}}</view>
      </view>

      <view class="my-field-card">
        <view class="login-label">全省排名：</view>
        <view class="my-static-value">{{profile.rank || '未填写'}}</view>
      </view>

      <view class="my-field-card">
        <view class="login-label">意向专业：</view>
        <view class="my-static-value my-static-multiline">{{profile.targetMajor || '未填写'}}</view>
      </view>

      <view class="my-field-card">
        <view class="login-label">报考偏好：</view>
        <view class="my-static-value my-static-multiline">{{profile.notes || '未填写'}}</view>
      </view>

      <view class="primary-btn my-primary-btn my-action-btn" hover-class="my-btn-hover" bindtap="openProfileEditor">编辑我的资料</view>
      <view class="ghost-btn danger-btn my-action-btn" hover-class="my-btn-hover" bindtap="logout">退出登录</view>
    </view>

    <view class="card my-form-card">
      <view class="my-form-title">关于我们</view>
      <view class="my-form-desc">查看产品定位、适用人群、联系方式，以及后端切换与网络诊断相关设置。</view>
      <view class="primary-btn my-primary-btn my-action-btn" hover-class="my-btn-hover" bindtap="openAboutPage">打开关于我们</view>
    </view>
  </view>
</view>