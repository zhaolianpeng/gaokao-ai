<view class="my-page">
  <view class="my-shell">
    <view class="card my-hero-card" wx:if="{{!user}}">
      <view class="my-title">我的</view>
      <view class="my-desc">登录后可保存考分、排名和报考偏好，并在首页自动带出。</view>
      <button class="ghost-btn my-ghost-btn" bindtap="openAboutPage">关于我们</button>
      <button class="primary-btn my-primary-btn" bindtap="goLogin">去登录</button>
      <button class="ghost-btn my-ghost-btn" bindtap="useDemoAccount">快速体验</button>
    </view>

    <view class="card my-profile-card" wx:if="{{user}}">
      <view class="my-badge">已登录</view>
      <view class="profile-head">
        <image wx:if="{{avatarDisplayUrl}}" class="profile-avatar" src="{{avatarDisplayUrl}}" mode="aspectFill"></image>
        <view wx:else class="profile-avatar profile-avatar-placeholder">{{userInitial}}</view>
        <view class="profile-meta">
          <view class="profile-title">{{user.nickname}}</view>
          <view class="profile-subtitle" wx:if="{{user.phone}}">手机号：{{user.phone}}</view>
        </view>
      </view>
      <view class="login-footnote">登录后保存的考分和偏好会在首页自动带出。</view>
      <view class="my-sync-card">
        <view class="my-sync-title">同步微信昵称和头像</view>
        <view class="my-sync-desc">点击后会自动尝试拉取微信头像昵称；如果微信未返回昵称，可手动补一个昵称一起同步。</view>
        <input class="input login-input" type="nickname" placeholder="请输入或确认微信昵称" value="{{syncDraftNickname}}" bindinput="onSyncNicknameInput" />
        <button class="ghost-btn my-ghost-btn" loading="{{syncSubmitting}}" bindtap="syncWechatProfile">同步到当前账号</button>
      </view>
      <button class="primary-btn my-primary-btn" bindtap="openVip">进入 VIP 中心</button>
    </view>

    <view class="card my-form-card" wx:if="{{user}}">
      <view class="my-form-title">我的报考档案</view>
      <view class="my-form-desc">完善基础信息后，可在推荐页和首页直接复用，减少重复填写。</view>

      <view class="my-field-card">
        <view class="login-label">地区：</view>
        <view class="my-static-value">黑龙江</view>
      </view>

      <view class="my-field-card">
        <view class="login-label">科类：</view>
        <picker mode="selector" range="{{subjectOptions}}" bindchange="onSubjectChange">
          <view class="mini-picker my-picker">{{profile.subject}}</view>
        </picker>
      </view>

      <view class="my-field-card">
        <view class="login-label">高考分数：</view>
        <input class="input login-input" type="number" placeholder="请输入分数" value="{{profile.score}}" data-field="score" bindinput="onInput" />
      </view>

      <view class="my-field-card">
        <view class="login-label">全省排名：</view>
        <input class="input login-input" type="number" placeholder="请输入位次" value="{{profile.rank}}" data-field="rank" bindinput="onInput" />
      </view>

      <view class="my-field-card">
        <view class="login-label">意向专业：</view>
        <input class="input login-input" placeholder="例如：计算机、临床医学" value="{{profile.targetMajor}}" data-field="targetMajor" bindinput="onInput" />
      </view>

      <view class="my-field-card">
        <view class="login-label">报考偏好：</view>
        <textarea class="textarea my-textarea" placeholder="例如：优先哈尔滨、接受调剂、尽量公办" value="{{profile.notes}}" data-field="notes" bindinput="onInput"></textarea>
      </view>

      <button class="primary-btn my-primary-btn" bindtap="saveProfile">保存我的资料</button>
      <button class="ghost-btn danger-btn" bindtap="logout">退出登录</button>
    </view>

    <view class="card my-form-card">
      <view class="my-form-title">VIP 服务</view>
      <view class="my-form-desc">服务端支付已经迁移到独立后端，购买前请先完成微信手机号登录。</view>
      <button class="primary-btn my-primary-btn" bindtap="openVip">打开 VIP 中心</button>
    </view>

    <view class="card my-form-card">
      <view class="my-form-title">关于我们</view>
      <view class="my-form-desc">查看产品定位、适用人群、联系方式，以及后端切换与网络诊断相关设置。</view>
      <button class="primary-btn my-primary-btn" bindtap="openAboutPage">打开关于我们</button>
    </view>
  </view>
</view>