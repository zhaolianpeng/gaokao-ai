.container {
  padding: 28rpx;
}

.row-between,
.plan-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.top-row {
  align-items: flex-start;
  gap: 16rpx;
}

.tip,
.empty-tip {
  margin-top: 10rpx;
  color: #5f738b;
  font-size: 24rpx;
  line-height: 1.7;
}

.share-result-shell {
  position: relative;
}

.share-result-layer {
  transition: filter 0.2s ease, transform 0.2s ease;
}

.share-result-layer-blurred {
  filter: blur(18rpx);
  transform: scale(0.992);
  pointer-events: none;
  user-select: none;
}

.share-modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(245, 241, 232, 0.3);
}

.share-modal-card {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 180rpx;
  z-index: 2;
  padding: 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 48rpx rgba(22, 53, 91, 0.18);
}

.share-lock-card {
  text-align: left;
}

.share-lock-desc {
  margin-top: 14rpx;
  color: #60748d;
  font-size: 24rpx;
  line-height: 1.8;
}

.link-btn {
  color: #175cd3;
  font-size: 24rpx;
}

.action-row {
  margin-top: 18rpx;
}

.toolbar-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.action-grid {
  display: flex;
  gap: 16rpx;
}

.filter-pill {
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #284b75;
  font-size: 24rpx;
}

.compare-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.summary-chip-row,
.compare-badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.summary-chip-row {
  margin-top: 14rpx;
}

.summary-chip,
.compare-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f1ff;
  color: #175cd3;
  font-size: 21rpx;
  font-weight: 700;
}

.compare-conclusion-card {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #fff8eb, #fff2dd);
}

.compare-conclusion-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #8a5a00;
}

.compare-conclusion-line {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #7a5a1f;
}

.compare-board {
  min-width: 100%;
}

.compare-grid {
  display: grid;
}

.compare-header,
.compare-row-grid {
  min-width: 920rpx;
}

.compare-cell {
  padding: 18rpx 16rpx;
  border-right: 1rpx solid #e6edf7;
  border-bottom: 1rpx solid #e6edf7;
  background: #ffffff;
  color: #38597f;
  font-size: 23rpx;
  line-height: 1.7;
  white-space: normal;
}

.compare-label-head,
.compare-column-head {
  background: #eef5ff;
  color: #16355b;
  font-weight: 700;
}

.compare-label-cell {
  background: #f8fbff;
  color: #16355b;
  font-weight: 700;
}

.compare-column-sub {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #60748d;
  font-weight: 400;
}

.compare-badge-row {
  margin-top: 10rpx;
}

.compare-value-cell-highlight {
  background: linear-gradient(180deg, #edf7ee, #e5f5e9);
  color: #166534;
  font-weight: 700;
}

.scenario-toggle-row {
  margin-top: 14rpx;
}

.scenario-toggle {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #175cd3;
  font-size: 22rpx;
  font-weight: 700;
}

.scenario-toggle-active {
  background: #dceafe;
  color: #16355b;
}

.export-pill {
  background: #dceafe;
  color: #175cd3;
}

.sequence-risk-card {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #f8fbff;
}

.sequence-risk-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.sequence-risk-badge-excellent {
  background: rgba(41, 160, 103, 0.14);
  color: #1f7a4c;
}

.sequence-risk-badge-good {
  background: rgba(31, 111, 235, 0.12);
  color: #1f6feb;
}

.sequence-risk-badge-warning {
  background: rgba(245, 158, 11, 0.14);
  color: #b45309;
}

.sequence-risk-badge-danger {
  background: rgba(220, 38, 38, 0.12);
  color: #b91c1c;
}

.sequence-risk-badge-pending {
  background: #edf2f7;
  color: #61748a;
}

.sequence-risk-line,
.sequence-risk-suggestion {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #60748d;
}

.sequence-risk-detail-title {
  margin-top: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #16355b;
}

.sequence-risk-detail-item {
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #ffffff;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.sequence-risk-detail-item-active {
  background: #eef5ff;
  box-shadow: inset 0 0 0 2rpx rgba(23, 92, 211, 0.16);
}

.sequence-risk-detail-tag {
  flex-shrink: 0;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #175cd3;
  font-size: 20rpx;
  font-weight: 700;
}

.sequence-risk-detail-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: #38597f;
}

.drag-plan-shell {
  margin-top: 20rpx;
}

.drag-plan-scroll {
  width: 100%;
}

.drag-plan-area {
  width: 100%;
  position: relative;
}

.drag-plan-placeholder {
  position: absolute;
  left: 0;
  right: 0;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(31, 111, 235, 0.08), rgba(31, 111, 235, 0.14));
  border: 2rpx dashed rgba(31, 111, 235, 0.35);
  box-sizing: border-box;
}

.drag-plan-view {
  width: 100%;
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}

.drag-plan-view-active {
  z-index: 3;
}

.drag-plan-item {
  box-sizing: border-box;
  height: 100%;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid #e6edf7;
  box-shadow: 0 10rpx 24rpx rgba(22, 53, 91, 0.05);
  transition: transform 0.18s ease, box-shadow 0.18s ease, opacity 0.18s ease;
}

.drag-plan-item-active {
  box-shadow: 0 18rpx 36rpx rgba(22, 53, 91, 0.14);
  border-color: #bfd4ff;
  transform: scale(1.01);
}

.drag-plan-item-ready {
  border-color: rgba(23, 92, 211, 0.28);
  box-shadow: 0 12rpx 28rpx rgba(23, 92, 211, 0.1);
}

.drag-plan-item-highlighted,
.plan-item-highlighted {
  background: linear-gradient(180deg, #eef5ff, #f8fbff);
  box-shadow: inset 0 0 0 2rpx rgba(23, 92, 211, 0.14);
}

.drag-plan-item-shifting {
  opacity: 0.92;
}

.drag-plan-order {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #eef5ff;
  color: #175cd3;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.drag-plan-main {
  flex: 1;
  min-width: 0;
}

.drag-plan-title {
  font-size: 28rpx;
}

.drag-plan-major {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.drag-plan-handle {
  flex-shrink: 0;
  padding: 10rpx 14rpx;
  border-radius: 14rpx;
  background: #eef5ff;
  color: #175cd3;
  font-size: 22rpx;
  font-weight: 700;
}

.drag-plan-handle-ready {
  background: #175cd3;
  color: #ffffff;
}

.ghost-btn {
  flex: 1;
  border-radius: 16rpx;
  background: #eef5ff;
  color: #175cd3;
  font-size: 24rpx;
}

.group-section {
  margin-top: 24rpx;
}

.group-title {
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #16355b;
}

.plan-item,
.favorite-item,
.scenario-item {
  padding: 22rpx 0;
  border-bottom: 1rpx dashed #e6edf7;
}

.scenario-pill {
  background: #dceafe;
  color: #175cd3;
}

.plan-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2d43;
}

.plan-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #60748d;
  line-height: 1.7;
}

.plan-foot {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #7b8ca3;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.tag-chong {
  background: #ffe7e7;
  color: #b42318;
}

.tag-wen {
  background: #e9f9ef;
  color: #067647;
}

.tag-bao {
  background: #e6f0ff;
  color: #175cd3;
}

.tag-other {
  background: #f2f4f7;
  color: #475467;
}

.plan-remove {
  color: #b42318;
}

@media (max-width: 420px) {
  .toolbar-row,
  .action-grid {
    flex-direction: column;
  }
}
