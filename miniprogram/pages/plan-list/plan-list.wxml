<view class="container">
  <view class="share-result-shell" wx:if="{{shareGateReady}}">
  <view class="share-result-layer {{!shareUnlocked ? 'share-result-layer-blurred' : ''}}">
  <view class="card" wx:if="{{compareBoard}}">
    <view class="row-between">
      <view class="section-title">方案并排比较</view>
      <view class="tip">已选 {{compareBoard.columns.length}} 套</view>
    </view>
    <view class="tip">先在下方勾选 2-3 套方案，这里会直接展开核心差异，适合和家长一起看。</view>
    <view class="summary-chip-row">
      <block wx:for="{{compareBoard.summaryChips}}" wx:key="*this">
        <view class="summary-chip">{{item}}</view>
      </block>
    </view>
    <view class="compare-conclusion-card" wx:if="{{compareBoard.conclusions.length}}">
      <view class="compare-conclusion-title">自动结论</view>
      <block wx:for="{{compareBoard.conclusions}}" wx:key="*this">
        <view class="compare-conclusion-line">{{index + 1}}. {{item}}</view>
      </block>
    </view>
    <scroll-view scroll-x="true" class="compare-scroll" enable-flex="true">
      <view class="compare-board">
        <view class="compare-header compare-grid" style="grid-template-columns: 180rpx repeat({{compareBoard.columns.length}}, 1fr);">
          <view class="compare-cell compare-label-head">比较项</view>
          <block wx:for="{{compareBoard.columns}}" wx:key="id">
            <view class="compare-cell compare-column-head">
              {{item.title}}
              <view class="compare-column-sub">{{item.total}} 组</view>
              <view class="compare-badge-row" wx:if="{{item.badges.length}}">
                <block wx:for="{{item.badges}}" wx:key="*this">
                  <view class="compare-badge">{{item}}</view>
                </block>
              </view>
            </view>
          </block>
        </view>
        <block wx:for="{{compareBoard.rows}}" wx:key="label">
          <view class="compare-grid compare-row-grid" style="grid-template-columns: 180rpx repeat({{compareBoard.columns.length}}, 1fr);">
            <view class="compare-cell compare-label-cell">{{item.label}}</view>
            <block wx:for="{{item.cells}}" wx:key="id">
              <view class="compare-cell compare-value-cell {{item.highlighted ? 'compare-value-cell-highlight' : ''}}">{{item.text}}</view>
            </block>
          </view>
        </block>
      </view>
    </scroll-view>
    <view class="action-row action-grid">
      <button class="ghost-btn" bindtap="openFamilyShareCard">生成家长沟通卡片</button>
      <button wx:if="{{showVipEntry}}" class="ghost-btn" bindtap="openVip">查看 VIP 深度服务</button>
    </view>
  </view>

  <view class="card">
    <view class="row-between">
      <view class="section-title">方案对比库</view>
      <view class="tip">已保存 {{scenarios.length}} 套</view>
    </view>
    <view class="tip">推荐页里保存的保结果版、保专业版、冲层次版会统一沉淀在这里，方便和家长老师对比。</view>
    <block wx:for="{{scenarios}}" wx:key="id">
      <view class="scenario-item">
        <view class="row-between top-row">
          <view class="plan-title">{{item.title}}</view>
          <view class="filter-pill scenario-pill">{{item.metrics.total}} 组</view>
        </view>
        <view class="plan-sub">{{item.desc}}</view>
        <view class="plan-sub">冲/较冲/稳/较保/保：{{item.metrics.chong}} / {{item.metrics.jiaoChong}} / {{item.metrics.wen}} / {{item.metrics.jiaoBao}} / {{item.metrics.bao}}，命中目标方向 {{item.metrics.targetHits}} 组</view>
        <view class="plan-sub">代表院校：{{item.collegeText}}</view>
        <view class="plan-foot">
          <text>{{item.timeText}}</text>
          <text>{{item.focus}}</text>
        </view>
        <view class="scenario-toggle-row">
          <view class="scenario-toggle {{item.selected ? 'scenario-toggle-active' : ''}}" data-id="{{item.id}}" bindtap="onToggleScenarioCompare">{{item.selected ? '已加入对比' : '加入并排比较'}}</view>
        </view>
        <view class="action-row action-grid">
          <button class="ghost-btn" data-id="{{item.id}}" bindtap="onApplyScenario">应用到正式志愿表</button>
          <button class="ghost-btn" data-id="{{item.id}}" bindtap="onRemoveScenario">移除方案</button>
        </view>
      </view>
    </block>
    <view class="empty-tip" wx:if="{{!scenarios.length}}">还没有保存的对比方案，先去推荐页保存一套。</view>
  </view>

  <view class="card">
    <view class="row-between">
      <view class="section-title">正式志愿表</view>
      <view class="link-btn" bindtap="onClearPlan">清空</view>
    </view>
    <view class="tip">先收藏专业组，再生成正式志愿表；也可以从推荐结果直接加入。</view>
    <view class="tip" wx:if="{{studentSummary && studentSummary.baseText}}">{{studentSummary.baseText}}</view>
    <view class="tip" wx:if="{{studentSummary && studentSummary.archiveText}}">档案上下文：{{studentSummary.archiveText}}</view>
    <view class="tip" wx:if="{{studentSummary && studentSummary.sourceText}}">{{studentSummary.sourceText}}</view>
    <view class="toolbar-row">
      <picker mode="selector" range="{{sortOptions}}" range-key="label" bindchange="onSortChange">
        <view class="filter-pill">排序：{{currentSortLabel}}</view>
      </picker>
      <view class="filter-pill export-pill" bindtap="onExportPlan">导出清单</view>
    </view>
    <view class="sequence-risk-card">
      <view class="row-between top-row">
        <view class="section-title section-title-small">顺序风险提示</view>
        <view class="sequence-risk-badge sequence-risk-badge-{{sequenceRisk.levelClass}}">{{sequenceRisk.level}} {{sequenceRisk.score ? sequenceRisk.score + '分' : ''}}</view>
      </view>
      <view class="tip">{{sequenceRisk.summaryText}}</view>
      <block wx:for="{{sequenceRisk.warnings}}" wx:key="*this">
        <view class="sequence-risk-line">{{index + 1}}. {{item}}</view>
      </block>
      <view class="sequence-risk-detail-title" wx:if="{{sequenceRisk.conflictDetails.length}}">具体冲突位置</view>
      <block wx:for="{{sequenceRisk.conflictDetails}}" wx:key="key">
        <view class="sequence-risk-detail-item {{activeConflictKey === item.key ? 'sequence-risk-detail-item-active' : ''}}" bindtap="onConflictDetailTap" data-key="{{item.key}}" data-first-id="{{item.firstId}}" data-second-id="{{item.secondId}}" data-first-index="{{item.firstIndex}}" data-second-index="{{item.secondIndex}}">
          <text class="sequence-risk-detail-tag">{{item.type}}</text>
          <text class="sequence-risk-detail-text">{{item.text}}</text>
        </view>
      </block>
      <block wx:for="{{sequenceRisk.suggestions}}" wx:key="*this">
        <view class="sequence-risk-suggestion">建议{{index + 1}}：{{item}}</view>
      </block>
    </view>
    <view class="action-row action-grid">
      <button class="ghost-btn" bindtap="onBuildFromFavorites">从收藏生成</button>
    </view>
    <view class="tip" wx:if="{{sortMode === 'manual'}}">当前为自定义顺序模式，请先长按右侧“拖动”手柄激活，再拖动调整顺序。</view>
    <view wx:if="{{sortMode === 'manual' && orderedApplicationList.length}}" class="drag-plan-shell">
      <scroll-view class="drag-plan-scroll" scroll-y="true" scroll-top="{{dragScrollTop}}" bindscroll="onDragListScroll" style="height: {{dragViewportHeightPx}}px;">
        <movable-area class="drag-plan-area" style="height: {{dragAreaHeightPx}}px;">
          <view
            wx:if="{{draggingPlanId && currentDropIndex >= 0}}"
            class="drag-plan-placeholder"
            style="top: {{currentDropIndex * dragRowHeightPx}}px; height: {{dragRowHeightPx}}px;"
          ></view>
          <block wx:for="{{dragPlanList}}" wx:key="id">
            <movable-view
              class="drag-plan-view {{draggingPlanId === item.id ? 'drag-plan-view-active' : ''}}"
              direction="vertical"
              disabled="{{dragReadyPlanId !== item.id}}"
              y="{{item.dragY}}"
              data-id="{{item.id}}"
              bindchange="onPlanDragChange"
              bindtouchstart="onPlanDragStart"
              bindtouchend="onPlanDragEnd"
              style="height: {{dragRowHeightPx}}px;"
            >
              <view class="drag-plan-item {{draggingPlanId === item.id ? 'drag-plan-item-active' : ''}} {{draggingPlanId && draggingPlanId !== item.id ? 'drag-plan-item-shifting' : ''}} {{highlightedPlanIds.indexOf(item.id) >= 0 ? 'drag-plan-item-highlighted' : ''}} {{dragReadyPlanId === item.id ? 'drag-plan-item-ready' : ''}}">
                <view class="drag-plan-order">{{item.orderIndex}}</view>
                <view class="drag-plan-main">
                  <view class="row-between top-row">
                    <view class="plan-title drag-plan-title">{{item.item.college_name}}</view>
                    <view class="tag tag-{{item.item.tag || 'other'}}">{{item.item.tag === 'chong' ? '冲刺' : item.item.tag === 'jiaochong' ? '较冲' : item.item.tag === 'wen' ? '稳妥' : item.item.tag === 'jiaobao' ? '较保' : item.item.tag === 'bao' ? '保底' : '待定'}}</view>
                  </view>
                  <view class="plan-sub">{{item.item.group_code}} {{item.item.group_name}} · 最低位次 {{item.item.min_rank}} · 最低分 {{item.item.min_score}}</view>
                  <view class="plan-sub drag-plan-major">{{item.item.majorPreview || item.item.matched_major || item.item.major}}</view>
                </view>
                <view class="drag-plan-handle {{dragReadyPlanId === item.id ? 'drag-plan-handle-ready' : ''}}" data-id="{{item.id}}" bindlongpress="onEnablePlanDrag">{{dragReadyPlanId === item.id ? '可拖动' : '长按拖动'}}</view>
              </view>
            </movable-view>
          </block>
        </movable-area>
      </scroll-view>
    </view>
    <block wx:for="{{groupedApplicationList}}" wx:key="key" wx:for-item="group">
      <view class="group-section" wx:if="{{sortMode !== 'manual'}}">
        <view class="group-title">{{group.title}} · {{group.items.length}} 组</view>
        <block wx:for="{{group.items}}" wx:key="id" wx:for-item="plan">
          <view class="plan-item {{highlightedPlanIds.indexOf(plan.id) >= 0 ? 'plan-item-highlighted' : ''}}">
            <view class="row-between top-row">
              <view class="plan-title">{{plan.item.college_name}}</view>
              <view class="tag tag-{{plan.item.tag || 'other'}}">{{plan.item.tag === 'chong' ? '冲刺' : plan.item.tag === 'jiaochong' ? '较冲' : plan.item.tag === 'wen' ? '稳妥' : plan.item.tag === 'jiaobao' ? '较保' : plan.item.tag === 'bao' ? '保底' : '待定'}}</view>
            </view>
            <view class="plan-sub">{{plan.item.group_code}} {{plan.item.group_name}} · {{plan.item.batch}}</view>
            <view class="plan-sub">选科 {{plan.item.subject_requirement}} · 最低位次 {{plan.item.min_rank}} · 最低分 {{plan.item.min_score}}</view>
            <view class="plan-sub">{{plan.item.majorPreview || plan.item.matched_major || plan.item.major}}</view>
            <view class="plan-foot">
              <text>{{plan.timeText}}</text>
              <text class="plan-remove" data-id="{{plan.id}}" bindtap="onRemovePlanItem">移除</text>
            </view>
          </view>
        </block>
      </view>
    </block>
    <view class="empty-tip" wx:if="{{!groupedApplicationList.length}}">正式志愿表还没有内容。</view>
  </view>

  <view class="card">
    <view class="section-title section-title-small">已收藏专业组</view>
    <block wx:for="{{favorites}}" wx:key="id">
      <view class="favorite-item">
        <view class="plan-title">{{item.item.college_name}}</view>
        <view class="plan-sub">{{item.item.group_code}} {{item.item.group_name}} · {{item.item.batch}}</view>
        <view class="plan-foot">
          <text>{{item.timeText}}</text>
          <text>可一键导入正式志愿表</text>
        </view>
      </view>
    </block>
    <view class="empty-tip" wx:if="{{!favorites.length}}">还没有收藏的专业组。</view>
  </view>
  </view>

  <view class="share-modal-mask" wx:if="{{!shareUnlocked}}"></view>
  <view class="share-modal-card" wx:if="{{!shareUnlocked}}">
    <view class="section-title">分享后查看志愿表与方案对比</view>
    <view class="share-lock-desc">方案对比和正式志愿表已经生成，当前先做模糊展示。分享当前小程序成功后，立即展示完整结果。</view>
    <button class="primary-btn" open-type="share" bindtap="requestShareUnlock">分享成功后查看完整结果</button>
  </view>
  </view>
</view>
