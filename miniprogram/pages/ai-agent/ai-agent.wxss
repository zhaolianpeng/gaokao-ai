.container {
  padding: 28rpx;
}

.hero-card {
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(19, 43, 74, 0.98), rgba(17, 117, 109, 0.92));
  color: #fff;
  box-shadow: 0 18rpx 34rpx rgba(17, 53, 74, 0.18);
}

.hero-badge {
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  font-size: 22rpx;
}

.hero-title {
  margin-top: 16rpx;
  font-size: 42rpx;
  font-weight: 800;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.84);
}

.field {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #edf2f8;
  font-size: 30rpx;
}

.fixed-field {
  color: #5c708a;
}

.picker-field {
  color: #16355b;
}

.input {
  margin-top: 20rpx;
  background: #f6f9ff;
  border-radius: 14rpx;
  padding: 20rpx;
}

.textarea {
  margin-top: 20rpx;
  min-height: 140rpx;
  background: #f6f9ff;
  border-radius: 14rpx;
  padding: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.textarea-lg {
  min-height: 240rpx;
}

.tip {
  margin-top: 12rpx;
  color: #5f738b;
  font-size: 24rpx;
  line-height: 1.7;
}

.template-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.template-chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #284b75;
  font-size: 22rpx;
}

.template-chip-active {
  background: #16355b;
  color: #ffffff;
}

.primary-btn {
  margin-top: 28rpx;
}

.task-status {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #f6f9ff;
  color: #27476c;
  font-size: 28rpx;
  line-height: 1.7;
}

.task-status.processing,
.task-status.pending {
  background: #eef6ff;
  color: #1f4f7e;
}

.task-status.succeeded {
  background: #edf9f1;
  color: #1f6b46;
}

.task-status.failed {
  background: #fff1f1;
  color: #a33a3a;
}

.task-error {
  margin-top: 16rpx;
  color: #a33a3a;
  font-size: 24rpx;
  line-height: 1.7;
}

.result-btn {
  margin-top: 24rpx;
  background: #16355b;
  color: #fff;
}