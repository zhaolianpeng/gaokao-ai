.policy-page {
  padding-bottom: 28rpx;
}

.policy-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 248, 255, 0.98));
}

.policy-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6f8198;
}

.policy-heading {
  margin-top: 28rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
  color: #16355b;
}

.policy-paragraph,
.policy-list-item {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.9;
  color: #4f6179;
}