page {
  background: linear-gradient(135deg, #f7fbff 0%, #eef4ff 100%);
  color: #1d2a39;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(10, 34, 66, 0.08);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #1f6feb, #0a84ff);
  color: #fff;
  border-radius: 16rpx;
}
